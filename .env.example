# Building Management Controller — Environment Variables
# Copy this file to .env and fill in values before running

# JWT secret for session tokens (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-hex-string

# Database connection (SQLite default)
DATABASE_URL=file:./prisma/dev.db

# App URL (used for redirects if behind a proxy)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
